{% extends '@nucleus/partials/particle.html.twig' %}
{% import '@particles/macros_helper.html.twig' as Macros %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ url('gantry-theme://css/leaflet.css') }}">
{% set has_styles = particle.particle_title_color or particle.particle_title_fontsize or particle.map_height or (particle.parallax_image and particle.container_maxwidth == 'custom' and particle.bg_container_width is not empty) %}
{% if has_styles %}
<style>
{%- if particle.particle_title_color or particle.particle_title_fontsize -%}#el-{{ id }}.g5-title{ {{ particle.particle_title_color ? 'color:' ~ particle.particle_title_color ~ ';' : '' }}{{ particle.particle_title_fontsize ? 'font-size:' ~ particle.particle_title_fontsize ~ 'px;' : '' }}}{% endif -%}
{%- if particle.map_height -%}#map{{ id }}{height:{{ particle.map_height|e }}px;z-index:1;}{% endif -%}
{%- if particle.parallax_image and particle.container_maxwidth == 'custom' and particle.bg_container_width is not empty -%}#{{ id }}-particle .g-container{max-width:{{ particle.bg_container_width|e }};}{% endif -%}
</style>
{% endif %}
{% endblock %}

{% block javascript %}
{% if (particle.animation == 'parallax' or particle.bg_image_effect == 'parallax') %}
    <script src="{{ url('gantry-theme://js/jlcomponents/parallax.min.js') }}"></script>
{% endif %}
{% endblock %}

{% set particle_classes = [
    id,
    particle.g_maxwidth != 'inherit' ? 'jl-width-' ~ particle.g_maxwidth ~ (particle.g_maxwidth_breakpoint != 'always' ? '@' ~ particle.g_maxwidth_breakpoint : '') ~ (particle.g_maxwidth_alignment == 'center' ? ' jl-margin-auto' : (particle.g_maxwidth_alignment == 'right' ? ' jl-margin-auto-left' : '')) : '',
    particle.align != 'inherit' ? 'jl-text-' ~ particle.align ~ (particle.breakpoint != 'always' ? '@' ~ particle.breakpoint ~ (particle.fallback != 'inherit' ? ' jl-text-' ~ particle.fallback : '') : '') : '',
    particle.animation == 'parallax' and particle.pa_z_index ? 'jl-position-z-index jl-position-relative' : '',
    particle.animation == 'parallax' and particle.parallax_transform_origin != 'center-center' ? 'jl-transform-origin-' ~ particle.parallax_transform_origin : '',
    particle.margin != 'inherit' ? (particle.margin != 'default' ? 'jl-margin-' ~ particle.margin : 'jl-margin') : '',
    particle.visibility != 'inherit' ? (particle.visibility in ['s', 'm', 'l', 'xl'] ? 'jl-visible@' ~ particle.visibility : 'jl-' ~ particle.visibility|replace({'-': '@'})) : '',
    particle.box_shadow != 'none' ? 'jl-box-shadow-' ~ particle.box_shadow : '',
    particle.box_shadow_hover != 'none' ? 'jl-box-shadow-hover-' ~ particle.box_shadow_hover : '',
    particle.class|default('')
] | filter(v => v)|join(' ')|trim %}

{% set attr_extra = particle.extra|attribute_array %}

{% block particle %}
{% if particle.enabled %}
{{- Macros.parallax_open(particle, id)|raw }}
{{ Macros.particle_title_style(particle, id)|raw }}
<div class="{{ particle_classes }}"{{ Macros.animation_render(particle)|raw }} {{- attr_extra|raw }}>
 <div id="map{{ id }}"></div>
</div>
{{- Macros.parallax_close(particle)|raw }}
{% endif %}
{% endblock %}

{% set attribution %}
{% if particle.contributors %}attribution: '&copy; <a href="https://www.mapbox.com/about/maps/">Mapbox</a> &copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a> <strong><a href="https://www.mapbox.com/map-feedback/" target="_blank">Improve this map</a></strong>',{% endif %}
{% endset %}
{% set mapstyle_url %}
{% if particle.mapstyle %}{{ particle.mapstyle|replace({'mapbox://styles/': ''}) }}{% endif %}
{% endset %}

{% block javascript_footer %}
<script src="{{ url('gantry-theme://js/leaflet.js') }}"></script>
<script src="{{ url('gantry-theme://js/leaflet-providers.js') }}"></script>
<script type="text/javascript">
{% for item in particle.items %}
{% if loop.index == '1' %}
var mymap = L.map('map{{ id }}', {zoomControl: {% if particle.zoom_control %}true{% else %}false{% endif %}, scrollWheelZoom: {% if particle.scroll_wheel %}true{% else %}false{% endif %} }).setView([{{item.latitude|e}}, {{item.longitude|e}}], {{particle.map_zoom|default('11')|e}});
{% endif %}
{% endfor %}
mymap.dragging.{% if particle.dragg %}enable{% else %}disable{% endif %}();
mymap.doubleClickZoom.{% if particle.double_click_zoom %}enable{% else %}disable{% endif %}();
{% if particle.accesstoken and particle.mapstyle %}
L.tileLayer('https://api.mapbox.com/styles/v1/{id}/tiles/{z}/{x}/{y}?access_token={accessToken}', {
	{{ attribution|raw }}
    maxZoom: {{particle.map_maxzoom}},
    tileSize: 512,
    zoomOffset: -1,
    id: '{% if particle.mapstyle %}{{mapstyle_url}}{% endif %}',
    accessToken: '{% if particle.accesstoken %}{{particle.accesstoken}}{% endif %}'
}).addTo(mymap);
{% else %}
L.tileLayer.provider('{{ particle.leaflet_providers|default('CartoDB.Voyager') }}', {maxZoom: {{particle.map_maxzoom}}}).addTo(mymap);
{% endif %}

var LeafIcon = L.Icon.extend({
    options: {
			iconSize: [25, 41],
			iconAnchor: [12, 41],
			popupAnchor: [1, -34],
			shadowSize: [41, 41]
    }
});

{% for item in particle.items %}

{% if item.icon %}

var icon_{{loop.index}} = new LeafIcon({iconUrl: '{{ url(item.icon)|e }}', shadowUrl: '{{ url(item.icon_shadow)|e }}'})

var marker = L.marker([{{item.latitude|e}}, {{item.longitude|e}}], {icon: icon_{{loop.index}}}).addTo(mymap);
{% else %}
var marker = L.marker([{{item.latitude|e}}, {{item.longitude|e}}]).addTo(mymap);
{% endif %}
{% if item.pop_content %}
marker.bindPopup("{{item.pop_content|e('js')}}"{% if item.pop_content_width %}, {maxWidth: "{{item.pop_content_width|e}}"}{% endif %}){% if particle.popup %}.openPopup(){% endif %};
{% endif %}
{% endfor %}
{% if particle.resize_event %}
// https://stackoverflow.com/a/36257493
setTimeout(function() {
    $('#g-page-surround').fadeIn('slow')
    mymap.invalidateSize(true)
}, 1500)
{% endif %}
</script>
{% endblock %}
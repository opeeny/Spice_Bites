{% extends '@nucleus/partials/particle.html.twig' %}
{% import '@particles/macros_helper.html.twig' as Macros %}

{% block stylesheets -%}
{% if particle.particle_title_color or particle.particle_title_fontsize or particle.customize_content_color or particle.customize_content_fontsize or (particle.parallax_image and particle.container_maxwidth == 'custom' and particle.bg_container_width is not empty) %}
<style>
{%- if particle.particle_title_color or particle.particle_title_fontsize -%}
#el-{{ id }}.g5-title{ {{ particle.particle_title_color ? 'color:' ~ particle.particle_title_color ~ ';' : '' }}{{ particle.particle_title_fontsize ? 'font-size:' ~ particle.particle_title_fontsize ~ 'px;' : '' }} }
{%- endif -%}
{%- if particle.customize_content_color or particle.customize_content_fontsize -%}
.{{ id }}{ {{ particle.customize_content_color ? 'color:' ~ particle.customize_content_color ~ ';' : '' }}{{ particle.customize_content_fontsize ? 'font-size:' ~ particle.customize_content_fontsize ~ 'px;' : '' }} }
{%- endif -%}
{%- if particle.parallax_image and particle.container_maxwidth == 'custom' and particle.bg_container_width is not empty -%}
#{{ id }}-particle .g-container{max-width:{{ particle.bg_container_width|e }};}
{%- endif -%}
</style>
{% endif %}
{% endblock %}

{% block javascript %}
{% if (particle.animation == 'parallax' or particle.bg_image_effect == 'parallax') %}
    <script src="{{ url('gantry-theme://js/jlcomponents/parallax.min.js') }}"></script>
{% endif %}
{% endblock %}

{% set dropcap = particle.dropcap ? ' jl-dropcap' : '' %}
{% set textcolor = particle.text_color != 'default' ? ' jl-text-' ~ particle.text_color|e : '' %}
{% set text_style = particle.text_style != 'default' ? ' jl-text-' ~ particle.text_style|e : '' %}
{% set text_size = particle.text_size != 'default' ? ' jl-text-' ~ particle.text_size|e : '' %}

{% set text_columns = particle.text_columns != 'none' 
    ? ' jl-column-' ~ particle.text_columns|e 
      ~ (particle.column_breakpoint != 'always' ? '@' ~ particle.column_breakpoint|e : '')
      ~ (particle.column_divider ? ' jl-column-divider' : '')
    : '' %}

{% set particle_classes = [
    id,
    'jl-panel',
    particle.g_maxwidth != 'inherit' ? 'jl-width-' ~ particle.g_maxwidth ~ (particle.g_maxwidth_breakpoint != 'always' ? '@' ~ particle.g_maxwidth_breakpoint : '') ~ (particle.g_maxwidth_alignment == 'center' ? ' jl-margin-auto' : (particle.g_maxwidth_alignment == 'right' ? ' jl-margin-auto-left' : '')) : '',
    particle.align != 'inherit' ? 'jl-text-' ~ particle.align ~ (particle.breakpoint != 'always' ? '@' ~ particle.breakpoint ~ (particle.fallback != 'inherit' ? ' jl-text-' ~ particle.fallback : '') : '') : '',
    particle.animation == 'parallax' and particle.pa_z_index ? 'jl-position-z-index jl-position-relative' : '',
    particle.animation == 'parallax' and particle.parallax_transform_origin != 'center-center' ? 'jl-transform-origin-' ~ particle.parallax_transform_origin : '',
    particle.margin != 'inherit' ? (particle.margin != 'default' ? 'jl-margin-' ~ particle.margin : 'jl-margin') : '',
    particle.visibility != 'inherit' ? (particle.visibility in ['s', 'm', 'l', 'xl'] ? 'jl-visible@' ~ particle.visibility : 'jl-' ~ particle.visibility|replace({'-': '@'})) : '',
    particle.class|default('')
] | filter(v => v)|join(' ')|trim %}

{% set html_element = particle.html_element ? particle.html_element|e : 'div' %}
{% set attr_extra = particle.extra|attribute_array %}

{% block particle %}
{% if particle.enabled %}
{{- Macros.parallax_open(particle, id)|raw }}
{{ Macros.particle_title_style(particle, id)|raw }}
<{{ html_element|e }} class=" {{ particle_classes ~ dropcap ~ textcolor ~ text_style ~ text_size ~ text_columns  }}"{{ Macros.animation_render(particle)|raw }} {{- attr_extra|raw }}>
    {% set html = particle.twig ? gantry.theme.compile(particle.content) : particle.content %}
    {{ (particle.filter ? gantry.platform.filter(html) : html)|html|raw }}
</{{ html_element|e }}>
{{- Macros.parallax_close(particle)|raw }}
{% endif %}
{% endblock %}

